<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:invoices.front.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="invoices.front.Views.InvoiceListView"
             x:DataType="vm:InvoiceListViewModel"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="16">
        <!-- Row 0: Search bar -->
        <TextBox Grid.Row="0" Text="{Binding SearchText}"
                 PlaceholderText="Search by establishment, CNPJ, or access key..."
                 Margin="0,0,0,8">
            <TextBox.InnerRightContent>
                <Button Content="Search" Command="{Binding SearchCommand}"/>
            </TextBox.InnerRightContent>
        </TextBox>

        <!-- Row 1: Month filter chips -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="All Invoices"
                        Command="{Binding SelectGroupCommand}"
                        CommandParameter="{x:Null}"
                        FontSize="13"
                        Padding="12,4"
                        Classes.accent="{Binding IsAllInvoicesSelected}"/>
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding FullLabel}"
                                    Command="{Binding $parent[ItemsControl].DataContext.SelectGroupCommand}"
                                    CommandParameter="{Binding}"
                                    FontSize="13"
                                    Padding="12,4"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Row 2: Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="{Binding DeleteButtonText}"
                    Command="{Binding DeleteSelectedCommand}"
                    IsVisible="{Binding HasSelection}"/>
            <Button Content="Export Report"
                    Command="{Binding ExportCommand}"
                    IsVisible="{Binding CanExport}"
                    IsEnabled="{Binding IsExporting, Converter={x:Static BoolConverters.Not}}"/>
            <TextBlock Text="{Binding ExportStatus}" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="12"/>
            <TextBlock Text="{Binding ErrorMessage}" VerticalAlignment="Center"
                       Foreground="Red" FontSize="12"/>
        </StackPanel>

        <!-- Row 3: DataGrid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Invoices}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Margin="0,0,0,8"
                  x:Name="InvoiceDataGrid">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Establishment"
                    Binding="{Binding Establishment.Name}" Width="2*"/>
                <DataGridTextColumn Header="CNPJ"
                    Binding="{Binding Establishment.Cnpj}" Width="*"/>
                <DataGridTextColumn Header="Date"
                    Binding="{Binding Date}" Width="*"/>
                <DataGridTextColumn Header="Total"
                    Binding="{Binding Total}" Width="*"/>
                <DataGridTextColumn Header="Valid"
                    Binding="{Binding IsValid}" Width="Auto"/>
                <DataGridTemplateColumn Header="Actions" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Details"
                                    Command="{Binding $parent[UserControl].DataContext.OpenDetailCommand}"
                                    CommandParameter="{Binding Id}"
                                    Margin="4" Padding="12,4"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 4: Pagination -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
            <Button Content="Previous" Command="{Binding GoToPreviousPageCommand}"
                    IsEnabled="{Binding CanGoToPrevious}"/>
            <TextBlock VerticalAlignment="Center">
                <Run Text="Page "/><Run Text="{Binding CurrentPage}"/>
                <Run Text=" of "/><Run Text="{Binding TotalPages}"/>
            </TextBlock>
            <Button Content="Next" Command="{Binding GoToNextPageCommand}"
                    IsEnabled="{Binding CanGoToNext}"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:invoices.front.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="invoices.front.Views.InvoiceDetailView"
             x:DataType="vm:InvoiceDetailViewModel"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto,*,Auto" Margin="24">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <TextBlock FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center">
                <Run Text="Invoice: "/>
                <Run Text="{Binding Invoice.AccessKey}"/>
            </TextBlock>
            <Button Grid.Column="1" Content="View Original PDF"
                    Command="{Binding ViewOriginalCommand}"
                    IsEnabled="{Binding !IsOpeningOriginal}"/>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <Grid ColumnDefinitions="1.5*,*" Margin="0,0,0,8">
                <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,12,0">
                    <StackPanel IsVisible="{Binding !IsEditing}">
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Status:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.IsValid}"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Establishment:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.Establishment}"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="CNPJ:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.Cnpj}"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Access Key:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.AccessKey}"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Date:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.Date}"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Total:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.Total}"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Parser:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.ParserVersion}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsEditing}">
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Establishment:" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Text="{Binding EditEstablishment}" PlaceholderText="Establishment"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="CNPJ:" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Text="{Binding EditCnpj}" PlaceholderText="CNPJ"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Date:" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Text="{Binding EditDate}" PlaceholderText="yyyy-MM-dd"/>
                        </Grid>
                        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
                            <TextBlock Text="Total:" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Text="{Binding EditTotal}" PlaceholderText="0.00"/>
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="Items" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,4"/>
                    <DataGrid ItemsSource="{Binding Invoice.Items}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="Auto"/>
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="*"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel IsVisible="{Binding HasErrors}">
                        <TextBlock Text="Parse Errors" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <ItemsControl ItemsSource="{Binding Invoice.ParseErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" Foreground="Red"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#1A1A27" CornerRadius="6" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Raw OCR Text" FontSize="16" FontWeight="SemiBold"/>
                        <ScrollViewer MaxHeight="500">
                            <TextBlock Text="{Binding Invoice.RawText}"
                                       FontFamily="Consolas, 'Courier New', monospace"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <StackPanel IsVisible="{Binding !IsEditing}" Orientation="Horizontal" Spacing="8">
                <Button Content="Edit" Command="{Binding EditCommand}"/>
                <Button Content="Delete" Command="{Binding DeleteCommand}"/>
            </StackPanel>
            <StackPanel IsVisible="{Binding IsEditing}" Orientation="Horizontal" Spacing="8">
                <Button Content="Save" Command="{Binding SaveCommand}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

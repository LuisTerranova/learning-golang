<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:invoices.front.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="invoices.front.Views.InvoiceUploadView"
             x:DataType="vm:InvoiceUploadViewModel">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="24">
        <TextBlock Grid.Row="0" Text="Upload Invoices (PDF)" FontSize="24" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <Button Content="Select PDFs" Command="{Binding SelectFileCommand}"/>
            <Button Content="{Binding UploadButtonText}"
                    Command="{Binding UploadCommand}"
                    IsEnabled="{Binding HasFiles}"/>
            <Button Content="Clear" Command="{Binding ClearFilesCommand}"
                    IsVisible="{Binding HasFiles}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" Margin="0,0,0,12">
            <ItemsControl ItemsSource="{Binding PendingFiles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PendingFile">
                        <Border Padding="8,6" Margin="0,0,0,4"
                                Background="#252538" CornerRadius="4">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" Text="&#x1F4C4;" FontSize="20"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontSize="13"/>
                                    <TextBlock Text="{Binding Error}"
                                               Foreground="Red" FontSize="11"
                                               IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                                <ProgressBar Grid.Column="2" Width="80" Height="6"
                                             VerticalAlignment="Center" IsIndeterminate="True"
                                             IsVisible="False"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" FontSize="13"/>
    </Grid>
</UserControl>
